{
  "compilerOptions": {
    "allowJs": false,
    "jsx": "react-native",
    "lib": ["esnext"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",
    "types": ["react", "react-native"]
  },
  "include": ["App.tsx", "src/**/*"]
}
